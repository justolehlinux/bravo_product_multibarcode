<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_bravo_product_multibarcode" model="ir.module.category">
        <field name="name">Bravo Product Barcodes</field>
        <field name="sequence">36</field>
    </record>
    <record id="privilege_bravo_product_multibarcode" model="res.groups.privilege">
        <field name="name">Product Multibarcode</field>
        <field name="category_id" ref="module_category_bravo_product_multibarcode"/>
        <field name="sequence">10</field>
    </record>
    <record id="group_bravo_multibarcode_user" model="res.groups">
        <field name="name">Bravo Multibarcode User</field>
        <field name="privilege_id" ref="privilege_bravo_product_multibarcode"/>
        <field name="sequence">10</field>
    </record>
    <record id="group_bravo_multibarcode_manager" model="res.groups">
        <field name="name">Bravo Multibarcode Manager</field>
        <field name="privilege_id" ref="privilege_bravo_product_multibarcode"/>
        <field name="sequence">20</field>
        <field name="implied_ids" eval="[(4, ref('group_bravo_multibarcode_user'))]"/>
    </record>
</odoo>
